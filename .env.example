# ==============================================================================
# Local dev only. In Vercel, set these via the dashboard or `vercel env add`.
# ==============================================================================

# NextAuth — generate the secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Okta OIDC — get from `terraform output` of the modules/poc-portal module
OKTA_ISSUER=https://your-org.oktapreview.com
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=

# Branding — all optional, NEXT_PUBLIC_* are exposed to the browser.
# Defaults render as generic "POC Portal" / "POC Implementation Guide".
NEXT_PUBLIC_BRAND_FULL_TITLE="Customer POC — Implementation Guide"
NEXT_PUBLIC_BRAND_LOGIN_TITLE="Customer POC Portal"
NEXT_PUBLIC_BRAND_LOGIN_SUBTITLE="Implementation Guide"
NEXT_PUBLIC_BRAND_LOGIN_HINT="Requires an account in the Customer POC Okta org"
NEXT_PUBLIC_BRAND_METADATA_TITLE="Customer POC Portal"
NEXT_PUBLIC_BRAND_METADATA_DESCRIPTION="Implementation guide for the POC."
